# Lokyy KI-OS — Environment Variables (Etappe-2)
#
# USAGE:
#   1. cp .env.example .env.local
#   2. chmod 0600 .env.local
#   3. Fill in real values
#   4. NEVER commit .env.local
#
# REFERENCE: ADR-003-docker-topology-etappe-2.md, ISC-54

# =====================================================================
# General
# =====================================================================

# Hostname for the Lokyy frontend + backend.
# Local dev tip: add `127.0.0.1 lokyy.local traefik.lokyy.local` to /etc/hosts.
DOMAIN=lokyy.local

# Hostname for the Traefik dashboard. Subdomain keeps it separate from app routing.
TRAEFIK_DASHBOARD_HOST=traefik.lokyy.local

# Hostname for the Hermes-internal web dashboard (Phase-2a).
# Used for `hermes setup` / `hermes login` flows.
HERMES_DASHBOARD_HOST=hermes.lokyy.local

# Forgejo lives REMOTELY (no container in this stack).
# Used by lokyy-brain in Phase-3 as its GIT_REMOTE.
# Format: https://USER:TOKEN@forgejo.example.com/owner/repo.git
LOKYY_BRAIN_FORGEJO_URL=

# Email used by Let's Encrypt for cert notifications.
ACME_EMAIL=admin@example.com

# =====================================================================
# Traefik Dashboard (basic-auth credentials)
# =====================================================================
#
# Generate via:
#   htpasswd -nbB admin 'STRONG-PASSWORD' | sed 's/\$/\$\$/g'
#
# Format: user:$$2y$$05$$hashed...
# (the $$ escapes a literal $ in docker-compose variable expansion)
TRAEFIK_DASHBOARD_AUTH=admin:$$2y$$05$$REPLACE_WITH_HTPASSWD_OUTPUT

# =====================================================================
# Phase-2 — Hermes Agent
# =====================================================================
#
# HERMES_API_KEY gates Hermes' OpenAI-compatible HTTP server on
# http://hermes:8642 inside lokyy-net. lokyy-installer generates it
# automatically (openssl rand -hex 32) on first `install`.
HERMES_API_KEY=

# At least one LLM provider key is required for Hermes to function.
# Pick whichever you already have (or sign up for free tier on OpenRouter).
# OPENROUTER_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# =====================================================================
# Phase-3 (lokyy-brain) — uncomment when activating
# =====================================================================
# lokyy-brain uses LOKYY_BRAIN_FORGEJO_URL (above) as its GIT_REMOTE.
# SUPADATA_API_KEY=

# ─── Phase-4: Lokyy System Bus (ADR-008) ───────────────────────────────────
# Bearer secret used by Lokyy System Skills (in lokyy-mcp container) to
# reach the privileged side of lokyy-mcp. Generate with:
#   openssl rand -hex 32
# Never commit a real value. Capability-Tokens (narrow scopes for User-Skills)
# are issued at runtime and don't need a static secret.
LOKYY_SYSTEM_SECRET=
