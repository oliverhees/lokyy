%% Lokyy Personal — Architektur Phase 0
%% Single-Tenant, lokale Installation, Better Auth + Hermes-Gateway
%% Siehe ADR-001 + ADR-002

flowchart TB
    Browser["Browser<br/>(127.0.0.1:3100)"]

    subgraph Lokyy["Lokyy-App (Vite Dev :3100)"]
        direction TB
        UI["React 19 + TanStack Router<br/>Tailwind 4 + shadcn UI"]
        AuthClient["@/lib/auth-client<br/>(Better Auth React)"]
        HermesClient["@/lib/hermes-gateway<br/>(typed Fetch)"]
        VitePlugin["Vite Middleware Plugin<br/>(/api/auth/* + /api/lokyy/*)"]
        ViteProxy["Vite Dev Proxy<br/>(/api/hermes/* → :8642)"]
        AuthServer["@/server/auth<br/>(Better Auth Instance)"]
    end

    subgraph Storage["lokyy-app/data/"]
        AuthDB[("auth.db<br/>SQLite + WAL<br/>user / session / account /<br/>organization / member ...")]
    end

    subgraph Hermes["Hermes-Agent (:8642)"]
        direction TB
        Gateway["Gateway HTTP<br/>(aiohttp)"]
        AgentEngine["Hermes-Agent Engine<br/>Conductor / Skills / MCP"]
    end

    subgraph External["LLM Provider"]
        Anthropic["Anthropic API<br/>claude-sonnet-4-6"]
    end

    %% Browser ↔ Lokyy
    Browser -->|GET / POST / SSE| UI
    UI --> AuthClient
    UI --> HermesClient

    %% Auth-Flow
    AuthClient -->|"/api/auth/*"| VitePlugin
    VitePlugin --> AuthServer
    AuthServer -->|prepare/select/insert| AuthDB

    %% Owner-Exists-Probe
    UI -.->|"/api/lokyy/owner-exists"| VitePlugin

    %% Hermes-Flow
    HermesClient -->|"/api/hermes/*<br/>(Origin stripped)"| ViteProxy
    ViteProxy -->|"/v1/chat/completions<br/>/v1/models<br/>/health"| Gateway
    Gateway --> AgentEngine
    AgentEngine -->|LLM call| Anthropic

    %% Style
    classDef store fill:#eef2ff,stroke:#6366f1,color:#1e1b4b
    classDef ext fill:#fff7ed,stroke:#ea580c,color:#7c2d12
    classDef proxy fill:#f0fdf4,stroke:#16a34a,color:#14532d
    class AuthDB store
    class Anthropic ext
    class VitePlugin,ViteProxy proxy
