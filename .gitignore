# ====================================================================
# Lokyy outer mono-repo .gitignore
# ====================================================================

# Internal development + AI-assistant artifacts. Kept locally so
# Claude-Code, BMAD agents and the diary workflow keep working, but
# excluded from the public-facing repo.
/CLAUDE.md
/ISA.md
/LOKYY.md
/LOKYY-ETAPPE-1-RESKIN.md
/docs/

# Inner workspace fork — lives as an independent repo at this path
# Cloned via `git clone https://github.com/outsourc-e/hermes-workspace.git lokyy-workspace`
# (Step 1.2 / Issue #2). Do NOT track from outer repo.
/lokyy-workspace/

# BMAD framework — installer-managed, regenerated on each install
# (config.toml says: "Regenerated on every install — treat as read-only")
# Project-shared customization lives in _bmad/custom/ and can be unignored later
# if/when we want to track team config.
/_bmad/
/_bmad-output/

# BMAD installer-generated IDE skill copies (mirror of global skills, not project state)
/.agents/
/.claude/

# Local hooks scratch
/.remember/

# Editor / OS
.DS_Store
*.swp
*~
.idea/
.vscode/

# Env files (never commit)
.env
.env.local
.env.*.local

# Node / pnpm (in case any tooling lands at outer level)
node_modules/

# Logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*
